# Terminal 0 - React
npm run dev

# Terminal 1 — Django
python manage.py runserver

# Terminal 2 — Celery worker
celery -A config worker --loglevel=info --pool=solo

# Terminal 3 — Celery beat (agendador)
celery -A config beat --loglevel=info


